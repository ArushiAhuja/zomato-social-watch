# ─────────────────────────────────────────────────────────────────────────────
# Zomato Social Watch — Environment Variables
# Copy this file to .env and fill in every value marked REQUIRED.
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude AI (REQUIRED) ──────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Reddit OAuth (optional — falls back to public API if blank) ──────────────
# Create a "script" type app at https://www.reddit.com/prefs/apps
# Your Reddit username (Certain-Lie2741) is used in the User-Agent per Reddit policy.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Twitter / X (optional — fetcher disabled if blank) ────────────────────────
# Option A: paste the Bearer Token directly from https://developer.twitter.com
TWITTER_BEARER_TOKEN=

# Option B: provide API Key + Secret — app derives the Bearer Token automatically
TWITTER_API_KEY=
TWITTER_API_SECRET=

# ── Extra RSS Feeds (optional) ────────────────────────────────────────────────
# Comma-separated RSS feed URLs to scrape alongside Google News.
# Example: RSS_FEEDS=https://techcrunch.com/feed/,https://yourblog.com/rss
RSS_FEEDS=

# ── Email Alerts (optional — leave blank to disable) ─────────────────────────
# Use a Gmail account + a 16-character App Password (NOT your login password).
# How to create an App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Search for "App Passwords" → create one for "Mail"
#   4. Copy the 16-char code (no spaces) here
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Comma-separated list of addresses to send escalation alerts to
ALERT_EMAIL=alerts@yourteam.com

# ── Google Sheets Logging (optional — leave blank to disable) ─────────────────
# Create a Google Sheet, share it with the service account email (editor access),
# then paste its ID here (the long string in the URL between /d/ and /edit).
GOOGLE_SHEET_ID=

# Service account credentials JSON — either paste the raw JSON or its base64 encoding.
# How to create a service account:
#   1. Go to https://console.cloud.google.com/iam-admin/serviceaccounts
#   2. Create a service account → create a JSON key → download it
#   3. Share your Google Sheet with the service account's email address
#   4. Paste the file contents here (as one line), or base64-encode it:
#      base64 -i service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express server listens on. Default: 3001
PORT=3001

# How often to auto-fetch and re-classify, in minutes. Default: 5
REFRESH_INTERVAL_MINUTES=5

# ── Classification ────────────────────────────────────────────────────────────
# Posts scoring at or above this threshold will trigger email/alert actions.
# Range: 0–100. Default: 60
ESCALATE_THRESHOLD=60

# ── Development ───────────────────────────────────────────────────────────────
# Set to true to log what emails/sheets WOULD be sent without actually sending.
# Keep true until you've verified credentials work.
DRY_RUN=true
